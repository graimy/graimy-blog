---
import BaseLayout from '../layouts/BaseLayout.astro';
import { AUTHOR, SITE_TITLE } from '../consts';
---

<BaseLayout title={`关于 · ${SITE_TITLE}`} description={AUTHOR.bio}>
	<header class="mb-10 border-b border-border pb-8">
		<p class="mb-3 text-xs font-semibold uppercase tracking-widest text-accent">{AUTHOR.title}</p>
		<h1 class="mb-4 font-serif text-3xl font-semibold md:text-4xl">{AUTHOR.name}</h1>
		<p class="text-lg leading-relaxed text-muted">{AUTHOR.bio}</p>
	</header>

	<div class="prose-blog">
		<h2>关于这个博客</h2>
		<p>
			这是一个用 <a href="https://astro.build/">Astro</a> 构建的静态博客，文章以 Markdown / MDX
			文件形式存放在本地，无需数据库。支持代码高亮、LaTeX 数学公式与暗黑模式，适合深夜阅读与写作。
		</p>

		<h2>你会在这里读到什么</h2>
		<ul>
			<li><strong>科研笔记</strong> — 文献阅读、方法思考、实证分析草稿</li>
			<li><strong>深度写作</strong> — 更长篇、更慢热的文字</li>
			<li><strong>电影随笔</strong> — 观影后的感受与联想</li>
			<li><strong>生活碎片</strong> — 不必严肃，但希望真诚</li>
		</ul>

		<h2>联系我</h2>
		<p>
			欢迎通过 <a href={`mailto:${AUTHOR.email}`}>邮件</a> 或
			<a href={AUTHOR.github} target="_blank" rel="noopener noreferrer">GitHub</a> 与我交流。
		</p>
	</div>
</BaseLayout>
