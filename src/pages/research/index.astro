---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../../consts';

const projects = (await getCollection('projects')).sort((a, b) => {
	if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
	const aDate = a.data.pubDate?.valueOf() ?? 0;
	const bDate = b.data.pubDate?.valueOf() ?? 0;
	return bDate - aDate;
});

const STATUS_LABELS = {
	active: '进行中',
	archived: '已归档',
	experiment: '实验中',
} as const;

const TOOL_STACK = [
	{ name: 'Python', category: '语言' },
	{ name: 'R', category: '语言' },
	{ name: 'Stata', category: '统计' },
	{ name: 'LaTeX', category: '写作' },
	{ name: 'Astro', category: '前端' },
	{ name: 'Git', category: '工具' },
];
---

<BaseLayout
	title={`科研 · ${SITE_TITLE}`}
	description="研究项目、学术成果与工具栈。"
	mainClass="max-w-4xl"
>
	<header class="mb-10">
		<h1 class="mb-3 font-serif text-3xl font-semibold md:text-4xl">科研与项目</h1>
		<p class="max-w-2xl text-muted">记录正在进行的研究、实验性探索，以及支撑日常工作的工具栈。</p>
	</header>

	<section class="mb-14">
		<h2 class="mb-5 font-serif text-xl font-semibold">项目</h2>
		<div class="grid gap-4">
			{
				projects.map((project) => (
					<article class="card">
						<div class="mb-2 flex flex-wrap items-center gap-2">
							<span class="tag active pointer-events-none text-[11px]">
								{STATUS_LABELS[project.data.status]}
							</span>
							{project.data.featured && (
								<span class="tag pointer-events-none text-[11px]">精选</span>
							)}
						</div>
						<h3 class="mb-2 font-serif text-lg font-semibold text-ink">{project.data.title}</h3>
						<p class="mb-4 text-sm leading-relaxed text-muted">{project.data.description}</p>
						<div class="flex flex-wrap gap-3 text-sm">
							{project.data.url && (
								<a href={project.data.url} target="_blank" rel="noopener noreferrer">
									项目链接
								</a>
							)}
							{project.data.repo && (
								<a href={project.data.repo} target="_blank" rel="noopener noreferrer">
									代码仓库
								</a>
							)}
						</div>
						{
							project.data.tags.length > 0 && (
								<div class="mt-4 flex flex-wrap gap-1.5">
									{project.data.tags.map((tag) => (
										<span class="tag pointer-events-none text-[11px]">{tag}</span>
									))}
								</div>
							)
						}
					</article>
				))
			}
		</div>
	</section>

	<section>
		<h2 class="mb-5 font-serif text-xl font-semibold">工具栈</h2>
		<div class="grid gap-3 sm:grid-cols-2 md:grid-cols-3">
			{
				TOOL_STACK.map((tool) => (
					<div class="card py-4">
						<p class="text-xs uppercase tracking-widest text-muted">{tool.category}</p>
						<p class="mt-1 font-medium text-ink">{tool.name}</p>
					</div>
				))
			}
		</div>
	</section>
</BaseLayout>
