---
import { getCollection } from 'astro:content';
import PostCard from '../../components/PostCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { BLOG_CATEGORIES, CATEGORY_LABELS, SITE_TITLE } from '../../consts';
import { getAllTags } from '../../utils/tags';
import { getReadingTime } from '../../utils/reading-time';

const activeCategory = Astro.url.searchParams.get('category');
const activeTag = Astro.url.searchParams.get('tag');

let posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

if (activeCategory && BLOG_CATEGORIES.some((c) => c.id === activeCategory)) {
	posts = posts.filter((post) => post.data.category === activeCategory);
}

if (activeTag) {
	posts = posts.filter((post) =>
		post.data.tags.some((tag) => tag.toLowerCase() === activeTag.toLowerCase()),
	);
}

const allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const tags = getAllTags(allPosts);
---

<BaseLayout
	title={`写作 · ${SITE_TITLE}`}
	description="科研笔记、深度写作与生活随笔。"
	mainClass="max-w-4xl"
>
	<header class="mb-10">
		<h1 class="mb-3 font-serif text-3xl font-semibold md:text-4xl">写作</h1>
		<p class="max-w-2xl text-muted">沉淀学术思考，记录阅读与生活。支持按分类与标签筛选。</p>
	</header>

	<div class="mb-8 flex flex-wrap gap-2">
		<a
			href="/blog/"
			class:list={['tag no-underline', !activeCategory && !activeTag && 'active']}
		>
			全部
		</a>
		{
			BLOG_CATEGORIES.map((category) => (
				<a
					href={`/blog/?category=${category.id}`}
					class:list={[
						'tag no-underline',
						activeCategory === category.id && 'active',
					]}
				>
					{CATEGORY_LABELS[category.id]}
				</a>
			))
		}
	</div>

	{
		tags.length > 0 && (
			<div class="mb-10 flex flex-wrap gap-2">
				{tags.map(({ tag }) => (
					<a
						href={`/blog/?tag=${encodeURIComponent(tag.toLowerCase())}`}
						class:list={[
							'tag no-underline text-[11px]',
							activeTag?.toLowerCase() === tag.toLowerCase() && 'active',
						]}
					>
						#{tag}
					</a>
				))}
			</div>
		)
	}

	<div class="grid gap-4">
		{
			posts.length > 0 ? (
				posts.map((post) => (
					<PostCard post={post} readingTime={getReadingTime(post.body ?? '')} />
				))
			) : (
				<p class="text-muted">暂无匹配的文章。</p>
			)
		}
	</div>
</BaseLayout>
