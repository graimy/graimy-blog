---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import MovieInfo from '../components/MovieInfo.astro';
import TableOfContents from '../components/TableOfContents.astro';
import type { TocHeading } from '../utils/toc';

interface Props extends CollectionEntry<'reviews'>['data'] {
	headings?: TocHeading[];
}

const { title, description, pubDate, year, country, genres, rating, headings = [] } = Astro.props;
---

<BaseLayout title={`${title} · 影评`} description={description} mainClass="max-w-5xl">
	<div class="mx-auto grid max-w-3xl gap-10 xl:grid-cols-[minmax(0,1fr)_200px] xl:max-w-none">
		<article>
			<MovieInfo title={title} year={year} country={country} genres={genres} rating={rating} />

			<section class="review-reflection mb-10">
				<div class="mb-6 flex items-center justify-between gap-4">
					<p class="text-[11px] font-medium uppercase tracking-[0.2em] text-accent/80">Reflection</p>
					<p class="text-xs text-muted">
						<FormattedDate date={pubDate} />
					</p>
				</div>
				<p class="review-lead text-lg md:text-xl">{description}</p>
			</section>

			<div class="prose-blog">
				<slot />
			</div>
		</article>

		<TableOfContents headings={headings} />
	</div>
</BaseLayout>
