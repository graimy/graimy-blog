---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import MovieInfo from './MovieInfo.astro';

interface Props {
	review: CollectionEntry<'reviews'>;
}

const { review } = Astro.props;
const { title, description, pubDate, year, country, genres, rating } = review.data;
---

<article class="review-card group">
	<a href={`/reviews/${review.id}/`} class="block no-underline">
		<MovieInfo
			title={title}
			year={year}
			country={country}
			genres={genres}
			rating={rating}
			variant="card"
		/>

		<div class="review-reflection">
			<p class="review-lead line-clamp-3">{description}</p>
			<p class="mt-4 text-xs text-muted/80">
				<FormattedDate date={pubDate} />
			</p>
		</div>
	</a>
</article>
