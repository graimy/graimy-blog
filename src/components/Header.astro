---
import { NAV_ITEMS, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="sticky top-0 z-50 border-b border-border/60 bg-paper/80 backdrop-blur-md">
	<nav class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-3 md:px-6">
		<a href="/" class="font-serif text-lg font-semibold tracking-tight text-ink no-underline hover:text-accent">
			{SITE_TITLE}
		</a>

		<div class="flex items-center gap-1 md:gap-2">
			<div class="hidden items-center gap-0.5 sm:flex">
				{
					NAV_ITEMS.map((item) => (
						<HeaderLink
							href={item.href}
							class="rounded-lg px-3 py-1.5 text-sm font-medium text-muted no-underline transition-colors hover:text-accent [&.active]:text-ink [&.active]:font-semibold"
						>
							{item.label}
						</HeaderLink>
					))
				}
			</div>
			<ThemeToggle />
		</div>
	</nav>

	<div class="flex gap-1 overflow-x-auto border-t border-border/40 px-4 py-2 sm:hidden md:px-6">
		{
			NAV_ITEMS.map((item) => (
				<HeaderLink
					href={item.href}
					class="tag shrink-0 no-underline [&.active]:border-accent [&.active]:text-accent"
				>
					{item.label}
				</HeaderLink>
			))
		}
	</div>
</header>
