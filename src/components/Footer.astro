---
import { AUTHOR, SITE_TITLE } from '../consts';

const year = new Date().getFullYear();
---

<footer class="mt-auto border-t border-border bg-paper-edge/30 px-4 py-10 text-center text-sm text-muted">
	<p class="mb-2 text-ink">
		&copy; {year} {SITE_TITLE}
	</p>
	<p class="mb-4">
		<a href={AUTHOR.github} class="font-medium" target="_blank" rel="noopener noreferrer">GitHub</a>
		<span class="mx-2 opacity-40" aria-hidden="true">·</span>
		<a href={`mailto:${AUTHOR.email}`} class="font-medium">{AUTHOR.email}</a>
		<span class="mx-2 opacity-40" aria-hidden="true">·</span>
		<a href="/rss.xml" class="font-medium">RSS</a>
	</p>
	<p class="text-xs opacity-70">沉静书写，缓慢积累。</p>
</footer>
